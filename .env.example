# Aegis Core — Example configuration
# Copy to .env and fill in real values, or run ./setup.sh to generate secrets automatically.

NODE_ENV=production

# ── Core ─────────────────────────────────────────────────────────────────────

AEGIS_PORT=8000
AEGIS_HOST=0.0.0.0

# Public-facing URL used in claim notification links
AEGIS_APP_URL=https://aegis.yourdomain.com

# SQLite database path (inside container: /data/aegis.db)
AEGIS_DB_PATH=/data/aegis.db

# Local data directory for packet files
AEGIS_DATA_DIR=/data

# Session secret — minimum 64 chars, must NOT contain "change-me" in production
AEGIS_SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_64

# Field encryption key — minimum 64 hex chars (32 bytes) in production
AEGIS_FIELD_ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32

# ── Notifications (configure via Settings UI after first login) ──────────────

AEGIS_SMTP_HOST=
AEGIS_SMTP_PORT=587
AEGIS_SMTP_USER=
AEGIS_SMTP_PASSWORD=
AEGIS_SMTP_FROM=

AEGIS_TELEGRAM_BOT_TOKEN=
AEGIS_TELEGRAM_CHAT_ID=

# ── S3-Compatible Storage — Dead Drop mode (configure via Settings UI) ────────

AEGIS_S3_ENDPOINT=          # leave blank for AWS S3, set for MinIO/R2/B2
AEGIS_S3_REGION=us-east-1
AEGIS_S3_BUCKET=
AEGIS_S3_ACCESS_KEY_ID=
AEGIS_S3_SECRET_ACCESS_KEY=
AEGIS_S3_PREFIX=aegis
# AEGIS_S3_FORCE_PATH_STYLE=true    # enable for MinIO and path-style providers

# ── Worker ───────────────────────────────────────────────────────────────────

# How often the worker ticks (seconds). Default: 60
# AEGIS_WORKER_INTERVAL_SECONDS=60
